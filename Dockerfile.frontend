# DivinityAI Frontend — Vite + React + Tailwind
FROM node:22-alpine

WORKDIR /app

# Copy package files
COPY frontend/package.json frontend/package-lock.json* ./

# Install dependencies
RUN npm install

# Copy frontend source
COPY frontend/ ./

EXPOSE 5173

# Dev server
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]