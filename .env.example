# Django
SECRET_KEY=django-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5899,http://localhost:8899
DATABASE_PATH=backend/db.sqlite3

# OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=DivinityAI

# ChromaDB (client-server mode, hosted at localhost:8040)
CHROMA_CLIENT_SERVER_MODE=True
CHROMA_HOST=localhost
CHROMA_PORT=8040
CHROMA_SSL=False
CHROMA_PERSIST_DIR=backend/chroma/chroma_data
CHROMA_EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_DEFAULT_COLLECTION=divinityai_documents
CHROMA_DISTANCE_METRIC=cosine

# Ollama Embeddings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=embeddinggemma

# ChromaDB collection names for Islamic corpus
QURAN_COLLECTION=quran_collection
HADITH_COLLECTION=hadith_collection

# RAG Pipeline
RAG_PHASE=2

# OpenRouter model overrides
OPENROUTER_GENERATION_MODEL=google/gemini-2.5-flash
OPENROUTER_CLASSIFIER_MODEL=google/gemini-2.5-flash
OPENROUTER_EVIDENCE_CHECK_MODEL=meta-llama/llama-3.3-70b-instruct
OPENROUTER_HALLUCINATION_MODEL=meta-llama/llama-3.3-70b-instruct

# BM25 Index Directory
BM25_INDEX_DIR=backend/corpus/bm25_indexes
